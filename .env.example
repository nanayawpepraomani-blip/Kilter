# Kilter — environment configuration template.
#
# Copy this file to `.env` and fill in real values BEFORE running
# `docker compose up`. Keep `.env` out of version control (already in
# .gitignore). For multi-environment deploys (dev / staging / prod), keep
# one .env per host, never commit them.

# ---------------------------------------------------------------------------
# REQUIRED — encryption key for at-rest secrets (TOTP secrets, SMTP creds).
# ---------------------------------------------------------------------------
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store it in your secret manager (Vault / AWS SM / 1Password) and inject
# at deploy time. Rotating this key requires re-encrypting every column
# the registry knows about — do it deliberately, with a maintenance window.
KILTER_SECRET_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — runtime tweaks
# ---------------------------------------------------------------------------

# Timezone reflected in audit log timestamps. Default UTC.
# TZ=Africa/Accra

# Override the database location inside the container. The compose file
# already sets this to /data/kilter.db (a mounted volume). Don't change
# unless you also adjust the volume mount.
# KILTER_DB_PATH=/data/kilter.db
