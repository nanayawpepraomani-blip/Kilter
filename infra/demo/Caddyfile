# Caddyfile for the hosted Kilter demo.
#
# Caddy auto-issues a Let's Encrypt cert for {$DEMO_HOSTNAME} on first
# start (so DNS must resolve to this host before `docker compose up`).
#
# Layered protection:
#   1. HTTP basic-auth gate — the only way past this is the credential
#      we email each prospect. Lifecycle is per-prospect; stale creds
#      get removed.
#   2. Kilter's normal MFA / TOTP / LDAP login still applies behind
#      the gate.
#
# So even if a prospect leaks their basic-auth pair, they still hit
# Kilter's login wall.

{
    email {$ACME_EMAIL}
    # Sensible defaults — explicit so we don't drift if Caddy's change.
    servers {
        protocols h1 h2
    }
}

{$DEMO_HOSTNAME} {
    encode zstd gzip

    # --- Belt-and-braces security headers ---------------------------
    # Caddy already adds reasonable defaults; we override here so the
    # demo's posture matches what the production deploy guide promises.
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Frame-Options            "DENY"
        X-Content-Type-Options     "nosniff"
        Referrer-Policy            "strict-origin-when-cross-origin"
        Permissions-Policy         "camera=(), microphone=(), geolocation=()"
        # Caddy's default Server header is innocuous; keep it.
        -X-Powered-By
    }

    # --- Basic-auth gate -------------------------------------------
    # Hash format: bcrypt. Generate with:
    #   docker run --rm caddy:2.8-alpine caddy hash-password --plaintext "your-password"
    basic_auth {
        {$DEMO_BASIC_AUTH_USER} {$DEMO_BASIC_AUTH_HASH}
    }

    # Kilter expects forwarded-for / proto headers (uvicorn started with
    # --proxy-headers in the base Dockerfile). Pass them through.
    reverse_proxy kilter:8000 {
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-For   {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Cap request size — matches the 300MB application middleware so
    # bigger uploads die at the edge with a clean 413, not a half-
    # streamed 502. Cards-side settlement files (Visa Base II, Mastercard
    # IPM, large issuer CSV) routinely run 250+ MB; SWIFT/Flex uploads
    # are still tiny but share the cap.
    request_body {
        max_size 300MB
    }
}
